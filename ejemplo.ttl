@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <http://espacio.org/naves/> .

# SUJETO (El recurso)
:astro1 a foaf:Person ; 

# PREDICADOS y OBJETOS (Las características)
    foaf:name "Comandante Astro" ;             # Literal (Texto) 
    foaf:mbox <mailto:astro@nasa.example> ;    # Recurso (IRI/Email) [cite: 12]
    foaf:img <http://bit.ly/foto-espacio> ;    # Recurso (Imagen) [cite: 13]
    foaf:homepage <https://astro.me> ;         # Recurso (Web) [cite: 14]
    
# RELACIÓN (Conexión con otro nodo)
    foaf:knows :robot_asistente .              # Objeto es otra IRI [cite: 15]


# --- P2: Ontología Local ---

# Definición de la Clase
:Estudiante a rdfs:Class ;
    rdfs:subClassOf foaf:Person ;
    rdfs:label "Estudiante" ;
    rdfs:comment "Una persona que está matriculada en una institución educativa" .

# Definición de la Propiedad
:estudiaEn a rdf:Property ;
    rdfs:label "estudia en" ;
    rdfs:comment "Relaciona a un estudiante con su universidad" ;
    rdfs:domain :Estudiante ;   # Quién estudia
    rdfs:range <http://www.wikidata.org/entity/Q43229> . # Rango: Una Organización (puedes usar la clase de Wikidata o FOAF)